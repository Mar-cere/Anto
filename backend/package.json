{
  "name": "proyectoanto-backend",
  "version": "1.4.2",
  "description": "Backend API para AntoApp - Aplicación de asistente AI terapéutico",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-achievements": "node scripts/initAchievements.js",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:watch": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:unit": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=unit",
    "test:prompt-golden": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/golden --no-coverage",
    "test:integration": "NODE_ENV=test NODE_OPTIONS=--max-old-space-size=4096 node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=integration --runInBand",
    "test:e2e": "NODE_ENV=test node tests/testEndToEndFlow.js",
    "test:full": "NODE_ENV=test NODE_OPTIONS=--max-old-space-size=4096 node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --runInBand",
    "quality:conversations": "node scripts/evaluateConversationQuality.js",
    "audit:push-en": "node scripts/audit-push-copy-en.mjs",
    "audit:email-en": "node scripts/audit-email-en.mjs",
    "audit:therapeutic-en": "node scripts/audit-therapeutic-techniques-en.mjs",
    "audit:psychoeducation-en": "node scripts/audit-psychoeducation-en.mjs",
    "audit:therapeutic-templates-en": "node scripts/audit-therapeutic-templates-en.mjs",
    "audit:api-routes": "node scripts/audit-api-routes-i18n.mjs",
    "audit:i18n": "npm run audit:api-routes && npm run audit:push-en && npm run audit:email-en && npm run audit:therapeutic-en && npm run audit:psychoeducation-en && npm run audit:therapeutic-templates-en",
    "generate:therapeutic-templates-en": "node scripts/generate-therapeutic-templates-en.mjs",
    "generate:psychoeducation-en": "node scripts/generate-psychoeducation-en.mjs",
    "smoke:psychoeducation": "node scripts/smoke-psychoeducation-device.mjs",
    "smoke:intervention-graph": "node scripts/smoke-intervention-graph-loop.mjs",
    "test:psychoeducation-chat": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/chatPsychoeducationSuggestions.test.js tests/unit/services/psychoeducationPromptSnippetService.test.js tests/unit/services/psychoeducationChatI18n.test.js tests/unit/constants/psychoeducationTopicsMeta.test.js --coverage=false",
    "test:abc-chat": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/chatAbcSuggestions.test.js tests/unit/services/actionSuggestionService.test.js tests/unit/services/abcRecordPrefillService.test.js tests/unit/constants/interventionCatalog.test.js tests/unit/utils/abcRecordSchemas.test.js tests/unit/utils/abcRecordApiCopy.test.js tests/unit/routes/abcRecordRoutes.i18n.test.js --coverage=false",
    "test:exposure-chat": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/chatExposureSuggestions.test.js tests/unit/services/exposurePlanPrefillService.test.js tests/unit/services/actionSuggestionService.test.js tests/unit/constants/interventionCatalog.test.js tests/unit/utils/exposurePlanSchemas.test.js tests/unit/utils/exposurePlanGuards.test.js tests/unit/routes/exposurePlanRoutes.i18n.test.js tests/unit/routes/chatContextAnalysis.suggestions.test.js --coverage=false",
    "test:ba-chat": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/chatBaSuggestions.test.js tests/unit/services/baRecordPrefillService.test.js tests/unit/services/techniqueSuggestionPrefills.test.js tests/unit/services/actionSuggestionService.test.js tests/unit/constants/interventionCatalog.test.js tests/unit/utils/behavioralActivationSchemas.test.js tests/unit/routes/behavioralActivationRoutes.i18n.test.js tests/unit/routes/chatContextAnalysis.suggestions.test.js --coverage=false",
    "test:at-chat": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/chatAtSuggestions.test.js tests/unit/services/atRecordPrefillService.test.js tests/unit/services/techniqueSuggestionPrefills.test.js tests/unit/services/actionSuggestionService.test.js tests/unit/constants/interventionCatalog.test.js tests/unit/constants/automaticThoughtDistortionPicker.test.js tests/unit/utils/automaticThoughtSchemas.test.js tests/unit/utils/automaticThoughtGuards.test.js tests/unit/routes/automaticThoughtRoutes.i18n.test.js tests/unit/routes/chatContextAnalysis.suggestions.test.js --coverage=false",
    "test:intervention-graph": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/utils/interventionTopicFree.test.js tests/unit/services/chatInterventionGraphService.test.js tests/unit/services/interventionRankingService.test.js tests/unit/services/activeTccProtocolsContextService.test.js --coverage=false",
    "test:ba-week-plan": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/behavioralActivationWeekPlanService.test.js tests/unit/services/behavioralActivationProductBridgeService.test.js tests/unit/services/activeTccProtocolsContextService.test.js tests/unit/routes/behavioralActivationRoutes.i18n.test.js --coverage=false",
    "test:tcc-continuity": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/chatTccContinuityService.test.js tests/unit/utils/tccContinuityCopy.test.js --coverage=false",
    "test:tcc-lite": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/chatTccLiteService.test.js --coverage=false",
    "test:session-insight": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/sessionInsightService.test.js tests/unit/services/sessionInsightHeadlineService.test.js --coverage=false",
    "test:greeting-chat": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/constants/greetingVariations.test.js tests/unit/services/openaiService.greeting.test.js tests/unit/services/guestChatWelcome.test.js --coverage=false",
    "test:tcc-chat": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/services/chatAbcSuggestions.test.js tests/unit/services/chatExposureSuggestions.test.js tests/unit/services/chatBaSuggestions.test.js tests/unit/services/chatAtSuggestions.test.js tests/unit/services/abcRecordPrefillService.test.js tests/unit/services/baRecordPrefillService.test.js tests/unit/services/atRecordPrefillService.test.js tests/unit/services/techniqueSuggestionPrefills.test.js tests/unit/services/actionSuggestionService.test.js tests/unit/routes/chatContextAnalysis.suggestions.test.js tests/unit/constants/interventionCatalog.test.js tests/unit/constants/greetingVariations.test.js tests/unit/services/openaiService.greeting.test.js --coverage=false",
    "test:tcc-suite": "npm run test:abc-chat && npm run test:exposure-chat && npm run test:ba-chat && npm run test:at-chat && npm run test:greeting-chat",
    "test:i18n": "NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern='apiRoutesI18nAudit|apiCopyParity|pushCopyEnAudit|emailEnAudit|EmailTemplate|emailLanguage|therapeuticTechniquesLocale|therapeuticTechniquesEnAudit|therapeuticApiCopy|therapeuticTechniquesRoutes.i18n|crisisRoutes.i18n|chatRoutes.i18n|authRoutes.i18n|authRoutes.registerDuplicate|authApiCopy|authErrorCodes|onboardingPromptSnippet|openaiPromptBuilder.onboarding|onboardingFocus|userApiCopy|journalApiCopy|journalRoutes.i18n|abcRecordApiCopy|abcRecordRoutes.i18n|abcRecordSchemas|notificationApiCopy|cognitiveDistortionsApiCopy|responseFeedbackApiCopy|clinicalScalesApiCopy|metricsApiCopy|cloudinaryApiCopy|testNotificationApiCopy|notificationEngagementApiCopy|summaryApiCopy|productApiCopy|crisisApiCopy|guestChatApiCopy|apiLanguage|psychoeducation|therapeuticTemplate|therapeuticTemplatesEn' --coverage=false",
    "generate:therapeutic-en": "node scripts/generate-therapeutic-techniques-en.mjs",
    "generate:mindfulness-en": "node scripts/generate-mindfulness-techniques-en.mjs",
    "fix:push-en": "node scripts/fix-push-en-templates.mjs",
    "fix:push-en:fallbacks": "ONLY=progressPositive,taskDueSoon,achievement,taskReminder node scripts/fix-push-en-templates.mjs"
  },
  "keywords": [
    "backend",
    "api",
    "express",
    "mongodb",
    "openai",
    "socket.io",
    "terapia",
    "ai"
  ],
  "author": "AntoApp Team",
  "license": "ISC",
  "dependencies": {
    "@apple/app-store-server-library": "^3.1.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.27.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.6.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "expo-server-sdk": "^4.0.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^144.0.0",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^2.9.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.11.0",
    "mongodb": "^6.13.0",
    "mongoose": "^8.13.1",
    "morgan": "^1.10.0",
    "nanoid": "^5.1.5",
    "nodemailer": "^7.0.10",
    "openai": "^4.95.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.3.5",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@sentry/profiling-node": "^10.27.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.0.0",
    "supertest": "^7.0.0",
    "typescript": "~5.7.0"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  }
}
