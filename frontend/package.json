{
  "name": "frontend",
  "version": "1.5.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:i18n": "jest --testPathPattern='translationsParity|translationsTone|dashboardI18n|dashboardTheme|dashboardHomeUtils|useTranslations|registerErrorUtils|registerAuthCopyParity|onboardingFocusParity|OnboardingQuestions|sessionWaiI18n' --coverage=false",
    "test:dashboard-suite": "npm run test:i18n",
    "test:exposure": "jest --testPathPattern='exposurePlanPrefill|exposurePlanAdvance|exposurePlanApiErrors' --coverage=false",
    "test:abc": "jest --testPathPattern='abcRecordPrefill|abcMacroDateRange|abcRecordsService|abcApiErrors|abcMacroCycle' --coverage=false",
    "test:abc-suite": "npm run test:abc",
    "test:ba": "jest --testPathPattern='baRecordPrefill|baApiErrors' --coverage=false",
    "test:chat-continuity": "jest --testPathPattern='tccContinuity|chatService.tccContinuity' --coverage=false",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "check:imports": "node scripts/check-duplicate-imports.js",
    "check:safe-area": "node scripts/check-safe-area-provider.js",
    "check": "npm run check:imports && npm run check:safe-area",
    "test:release-1.5.0": "jest --testPathPattern='release150\\.guard|dashboardHomeRefresh|subscriptionPaywall|onboarding\\.guard|profileProgress\\.guard|techniquesHub\\.guard|socialLinks|translationsParity|translationsTone' --coverage=false",
    "test:insights": "jest --testPathPattern='summaryScreen|weeklyInsight|summaryScreenUtils|weeklyInsightUtils|insightsExperience|insightsI18nParity|summaryWeeklyInsightI18n' --coverage=false",
    "validate:release-1.5.0": "npm run check && npm run test:release-1.5.0",
    "validate:insights": "npm run check && npm run test:insights",
    "test:welcome-auth": "jest --testPathPattern='welcomeAuth|welcomeScreenTheme' --coverage=false",
    "validate:welcome-auth": "npm run check && npm run test:welcome-auth",
    "test:e2e:maestro": "maestro test e2e/maestro/chat-roundtrip-from-tabs.yaml",
    "test:e2e:maestro:login-chat": "maestro test e2e/maestro/login-chat-send.yaml",
    "test:e2e:maestro:psychoed": "maestro test e2e/maestro/psychoeducation-twelve-modules.yaml",
    "postinstall": "node -e \"try { const pkg = require('./node_modules/@react-native/normalize-colors/package.json'); if (!pkg.main) { pkg.main = 'index.js'; require('fs').writeFileSync('./node_modules/@react-native/normalize-colors/package.json', JSON.stringify(pkg, null, 2)); } } catch(e) {}\""
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.1.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native/normalize-colors": "^0.83.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.1.17",
    "@react-navigation/stack": "^7.1.1",
    "@sentry/react-native": "~7.2.0",
    "axios": "^1.7.9",
    "babel-preset-expo": "~54.0.8",
    "expo": "~54.0.29",
    "expo-blur": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-health-connect": "^0.1.1",
    "expo-image-picker": "~17.0.10",
    "expo-in-app-purchases": "^14.5.0",
    "expo-notifications": "~0.32.15",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-health": "^1.19.0",
    "react-native-health-connect": "^3.5.3",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "expo-build-properties": "~0.14.8",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.12",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "get-symbol-description": "1.0.2"
  },
  "expo": {
    "autolinking": {
      "android": {
        "exclude": [
          "expo-in-app-purchases"
        ]
      }
    }
  },
  "private": true
}
