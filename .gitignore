# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
.kotlin/
*.orig.*
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision

# App Store / Play — artefactos de build (EAS/Xcode/Gradle locales; no subir binarios)
*.ipa
*.apk
*.aab
*.xcarchive
*.dSYM.zip

# EAS: export local de credenciales (la gestión normal es en expo.dev)
credentials.json
eas-credentials.json

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# logs
logs/

# macOS
.DS_Store
*.pem
# Certificado raíz público Apple (PKI); necesario en Render para ASN V2
!backend/certs/apple_root_ca_g3.pem

# local env files
.env
.env*.local
.env.local
backend/.env
frontend/.env
# variantes por entorno (mantener solo plantillas versionadas, p. ej. .env.example)
.env.*
!.env.example
!.env*.example
!.env.sample

# typescript
*.tsbuildinfo

# tests / CI — salidas generadas (no versionar informes locales)
coverage/
**/coverage/
.nyc_output/

app-example

# Obsidian — notas generadas (vault real está fuera del repo; ver docs/obsidian-propuestas/README.md)
docs/obsidian-propuestas/*
!docs/obsidian-propuestas/README.md
.anto-obsidian-export.json

# generated native folders
/ios
/android
